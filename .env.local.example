# Rename this file to .env.local and fill in your values.
# Get these from: Firebase Console → Project Settings → Your Apps → Web App → Config

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Only needed for presence & typing indicators (Realtime Database)
# Found in: Firebase Console → Realtime Database → your DB URL
NEXT_PUBLIC_FIREBASE_DATABASE_URL=
