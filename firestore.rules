rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    match /chats/{chatId} {
     
      allow read, write: if request.auth != null
                         && request.auth.uid in resource.data.members;

      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.members;


      match /messages/{messageId} {
        allow read: if request.auth != null
                    && isMember(request.auth.uid, chatId);

        allow create: if request.auth != null
                      && isMember(request.auth.uid, chatId)
                      && request.resource.data.senderId == request.auth.uid;

        allow update: if request.auth != null
                      && isMember(request.auth.uid, chatId)
                      && (
                        (resource.data.senderId == request.auth.uid
                          && onlyChanging(['text','isEdited','isDeleted',
                                          'deletedFor','pinnedMessage',
                                          'reactions','starredBy']))
                        ||
                        onlyChanging(['reactions','deletedFor','starredBy'])
                        ||
                        onlyChanging(['status'])
                      );

        allow delete: if false;
      }
    }

    match /calls/{callId} {
      allow read: if request.auth != null
                  && request.auth.uid in resource.data.members;

      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.callerId
                    && request.auth.uid in request.resource.data.members;

      allow update, delete: if false;
    }

    match /conversations/{convId}/messages/{msgId} {
      allow read: if request.auth != null
                  && isParticipant(request.auth.uid, convId);
      allow create: if request.auth != null
                    && isParticipant(request.auth.uid, convId)
                    && request.resource.data.senderId == request.auth.uid;
      allow update: if request.auth != null
                    && isParticipant(request.auth.uid, convId);
      allow delete: if false;
    }
  }

  function isMember(uid, chatId) {
    return uid in get(/databases/$(database)/documents/chats/$(chatId)).data.members;
  }

  function isParticipant(uid, convId) {
    let parts = convId.split('_');
    return parts.size() == 2 && (parts[0] == uid || parts[1] == uid);
  }

  function onlyChanging(fields) {
    return request.resource.data.diff(resource.data).affectedKeys().hasOnly(fields);
  }
}
