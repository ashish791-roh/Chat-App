rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    match /conversations/{convId}/messages/{msgId} {
      allow read: if request.auth != null
        && isParticipant(request.auth.uid, convId);

      allow create: if request.auth != null
        && isParticipant(request.auth.uid, convId)
        && request.resource.data.senderId == request.auth.uid;


        allow update: if request.auth != null
          && isParticipant(request.auth.uid, convId)
          && (
            (resource.data.senderId == request.auth.uid
              && onlyChanging(['isDeleted', 'text', 'reactions', 'deletedForUsers']))
            ||
            (resource.data.recipientId == request.auth.uid
              && onlyChanging(['status']))
          );

      allow delete: if false; 
    }
  }

  function isParticipant(uid, convId) {
    let parts = convId.split('_');
    return parts.size() == 2 && (parts[0] == uid || parts[1] == uid);
  }

  function onlyChanging(fields) {
    return request.resource.data.diff(resource.data).affectedKeys().hasOnly(fields);
  }
}
